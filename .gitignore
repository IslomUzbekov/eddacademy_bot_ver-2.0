# =========================================================
# EDD Academy Telegram Bot — .gitignore
# Stack:
# Django + DRF + aiogram + PostgreSQL + Redis + Celery
# =========================================================

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# ---------------------------------------------------------
# Virtual Environment
# ---------------------------------------------------------
venv/
env/
ENV/
.venv/

# ---------------------------------------------------------
# Environment variables
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# Django
# ---------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Static & media
staticfiles/
media/

# ---------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.tmp
*.bak

# ---------------------------------------------------------
# OS files
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------
# Pytest / Coverage
# ---------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.cache/

# ---------------------------------------------------------
# Mypy / Ruff / Type checkers
# ---------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pyre/

# ---------------------------------------------------------
# Celery
# ---------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# ---------------------------------------------------------
# Redis dump
# ---------------------------------------------------------
dump.rdb

# ---------------------------------------------------------
# Docker
# ---------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------
# Secrets / Configs
# ---------------------------------------------------------
config/bot_config.py
config/local.py
secrets.json

# ---------------------------------------------------------
# PostgreSQL data
# ---------------------------------------------------------
postgres_data/

# ---------------------------------------------------------
# Redis data
# ---------------------------------------------------------
redis_data/

# ---------------------------------------------------------
# Uploaded files
# ---------------------------------------------------------
uploads/

# ---------------------------------------------------------
# Node.js (if frontend/admin panel exists)
# ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------
# Frontend build
# ---------------------------------------------------------
frontend/build/
frontend/dist/

# ---------------------------------------------------------
# Backup files
# ---------------------------------------------------------
*.backup
*.old
*.orig

# ---------------------------------------------------------
